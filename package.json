{
  "name": "claude-review-dashboard",
  "version": "0.1.0",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"electron/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "pack": "electron-vite build && electron-builder",
    "pack:dir": "electron-vite build && electron-builder --dir"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.200"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@radix-ui/react-checkbox": "^1.3.6",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.16",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "lucide-react": "^1.23.0",
    "prettier": "^3.9.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shiki": "^4.3.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "use-intl": "^4.13.1",
    "vite": "^7.3.6",
    "zod": "^4.4.3"
  },
  "build": {
    "appId": "com.claudereview.dashboard",
    "productName": "Claude Review Dashboard",
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/@anthropic-ai/**"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools"
    },
    "directories": {
      "buildResources": "build",
      "output": "release"
    }
  }
}
